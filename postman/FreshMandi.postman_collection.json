{
  "info": {
    "name": "Fresh Mandi API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://backend-rho-one-36.vercel.app/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Request OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/otp/request",
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\"\n}" }
      }
    },
    {
      "name": "Auth - Verify OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/otp/verify",
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\"\n}" }
      }
    },
    {
      "name": "Catalog - Categories",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/categories"
      }
    },
    {
      "name": "Cart - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/cart"
      }
    },
    {
      "name": "Orders - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address_id\": 1,\n  \"slot_id\": 1,\n  \"payment_mode\": \"COD\",\n  \"coupon_code\": \"FRESH50\",\n  \"wallet_redeem\": 0\n}"
        }
      }
    },
    {
      "name": "Payments - Create Intent",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/payments/create-intent",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order_id\": 1,\n  \"amount\": 500,\n  \"provider\": \"RAZORPAY\"\n}"
        }
      }
    },
    {
      "name": "Payments - Confirm",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/payments/confirm",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reference\": \"PMT-000\",\n  \"order_id\": 1,\n  \"status\": \"SUCCESS\"\n}"
        }
      }
    }
  ]
}
